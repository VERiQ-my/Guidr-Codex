NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# GPT-5.6 Terra powers attachment parsing and the primary scan lane.
OPENAI_API_KEY=

# Databricks powers the independent Malaysian intelligence lane.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_ENDPOINT_NAME=databricks-meta-llama-3-3-70b-instruct
# Optional dedicated MaLLaM endpoint. Falls back to DATABRICKS_ENDPOINT_NAME.
DATABRICKS_MALLAM_ENDPOINT_NAME=
DATABRICKS_AI_SEARCH_ENDPOINT=guidr-scam-search
DATABRICKS_AI_SEARCH_INDEX=guidr.scam_intelligence.scam_patterns_index
DATABRICKS_EMBEDDING_ENDPOINT=databricks-qwen3-embedding-0-6b

# Use a long random value in deployed environments for signed queue tickets.
SCAN_QUEUE_SECRET=
OPENAI_TIMEOUT_MS=30000
DATABRICKS_TIMEOUT_MS=25000
# Optional: point at the local Firebase emulator instead of prod
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Server-only Firebase Admin credentials. Use one option; never prefix these with NEXT_PUBLIC_.
# FIREBASE_SERVICE_ACCOUNT_JSON={...}
# FIREBASE_SERVICE_ACCOUNT_PATH=.firebase-service-account.json

# Optional dedicated secret for short-lived scan queue tickets.
# SCAN_QUEUE_SECRET=use-a-long-random-server-only-value
